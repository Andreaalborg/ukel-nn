# =============================================================================
# Supabase (public — eksponeres til klient via NEXT_PUBLIC_)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://din-prosjekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=din-anon-public-key

# Brukes som fallback-base-URL for API-routes (skal være full origin)
NEXT_PUBLIC_SITE_URL=https://gjore.no

# =============================================================================
# Supabase service role (SERVER ONLY — eksponer ALDRI til klient)
# Finn denne i Supabase: Project Settings → API → service_role
# =============================================================================
SUPABASE_SERVICE_ROLE_KEY=ditt-service-role-secret

# =============================================================================
# Stripe (SERVER ONLY for STRIPE_SECRET_KEY og webhook secret)
# =============================================================================
# Test mode under utvikling, byttes til live mode ved launch
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs fra Stripe Dashboard → Catalog → Products
STRIPE_PRICE_FAMILY_MONTHLY=price_test_...
STRIPE_PRICE_FAMILY_YEARLY=price_test_...
STRIPE_PRICE_LIFETIME=price_test_...

# Publishable key — eksponeres til klient (trygt)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# =============================================================================
# Resend (når satt opp som SMTP-leverandør i Supabase, eller egen sender)
# =============================================================================
# RESEND_API_KEY=re_...
